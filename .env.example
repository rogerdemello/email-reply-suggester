# Copy this file to `.env` and fill in your key.

# --- Required for live runs (NVIDIA NIM, OpenAI-compatible) ---
# Get a key at https://build.nvidia.com  (free tier available)
NVIDIA_API_KEY=

# --- Optional overrides (sensible defaults are baked in) ---
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# GEN_MODEL=meta/llama-3.3-70b-instruct
# JUDGE_MODEL=meta/llama-3.3-70b-instruct
# EMBED_MODEL=nvidia/nv-embedqa-e5-v5
# RETRIEVAL_K=3
# GEN_TEMPERATURE=0.4
# JUDGE_TEMPERATURE=0.0
# PASS_THRESHOLD=3.5

# --- Smoke test only ---
# Set USE_MOCK=1 to run the full pipeline end-to-end WITHOUT any API key, using a
# deterministic local stand-in backend (no network). Useful to verify the plumbing
# and to produce example outputs. It is NOT representative of real model quality -
# unset it and provide NVIDIA_API_KEY for real results.
# USE_MOCK=0
